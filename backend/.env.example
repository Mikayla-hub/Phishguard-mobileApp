# PhishGuard Backend Configuration
# Copy this file to .env and fill in your values

# ===== Server Configuration =====
PORT=3001
NODE_ENV=development

# ===== Database =====
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
JWT_SECRET=your-jwt-secret-key-change-this

# ===== CORS Configuration =====
CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# ===== ML Server Configuration =====
# URL to the Python ML server (running on port 5000)
ML_SERVER_URL=http://localhost:5000

# ===== Vision/OCR APIs =====
# Google Gemini Vision API (for OCR)
GEMINI_API_KEY=your-gemini-api-key

# Groq API (alternative/fallback for Vision OCR)
GROQ_API_KEY=your-groq-api-key

# ===== Email Service =====
# For sending phishing alerts via email
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your-sendgrid-key
EMAIL_FROM=noreply@phishguard.app

# ===== Logging =====
LOG_LEVEL=info
